<roblox version="4">
  <Item class="ModuleScript" referent="0">
    <Properties>
      <string name="Name">sendbufs</string>
      <string name="Source"><![CDATA[local Players = game:GetService('Players')
local RunService = game:GetService('RunService')
local serdes = require(script:WaitForChild('serdes'))
local is_server = RunService:IsServer()
local server = require(script:WaitForChild('server-lifecycle'))
local client = require(script:WaitForChild('client-lifecycle'))
local remotes = require(script:WaitForChild('remotes'))
local metatables = require(script:WaitForChild('metatables'))
local constants = require(script:WaitForChild('constants'))
local middleware = require(script:WaitForChild('middleware'))

export type TEvent<T=never> = metatables.t_event<T>
export type TFunction<T=never, R=never> = metatables.t_fn<T, R>
export type TReplicated<T=never, R=never> = metatables.t_event<T> | metatables.t_fn<T, R>

do
    local globalid = 0

    function take_next()
        globalid += 1

        return globalid
    end
    function add<T>(t: T): T
        remotes[globalid] = t::never

        return t
    end
end

function create_event<T>(t: T): metatables.t_event<T>
    return add(setmetatable({
        kind = 'event',
        listeners = {},
        schema = t,
        type = constants.EVENT_TYPE.RELIABLE,
        id = take_next(),
    }, if is_server then metatables.server_remote_metatable else metatables.client_remote_metatable))::never
end
function create_unreliable<T>(t: T): metatables.t_event<T>
    return add(setmetatable({
        kind = 'event',
        listeners = {},
        schema = t,
        type = constants.EVENT_TYPE.UNRELIABLE,
        id = take_next(),
    }, if is_server then metatables.server_remote_metatable else metatables.client_remote_metatable)::never)
end
function create_request<T, R>(input: T, output: R): metatables.t_fn<T, R>
    return add(setmetatable({
        callback = nil,
        kind = 'function',
        schema = input,
        schema_out = output,
        id = take_next(),
    }, if is_server then metatables.server_function_metatable else metatables.client_function_metatable)::never)
end

if is_server then
    server.start()
else
    client.start()
end

return table.freeze({
    create_event = create_event,
    create_unreliable = create_unreliable,
    create_request = create_request,
    middleware = middleware.middleware::<T, R>(evt:metatables.t_event<T> | metatables.t_fn<T, R>, fn:(id:number, plr:Player, b:buffer, refs:{unknown}?) -> boolean) -> (),
    global_middleware = middleware.global_middleware::(fn:(id:number, plr:Player, b:buffer, refs:{unknown}?) -> boolean) -> (),
    schema = serdes,
})
]]></string>
    </Properties>
    <Item class="ModuleScript" referent="1">
      <Properties>
        <string name="Name">buffer-writer</string>
        <string name="Source"><![CDATA[export type buffer_writer = {size: number, cursor: number, references: {unknown}, buff: buffer}

function create(): buffer_writer
    return {
        size = 12,
        references = {},
        buff = buffer.create(12),
        cursor = 0,
    }
end
function from(b: buffer)
    local len = buffer.len(b)
    local nb: buffer_writer = {
        buff = buffer.create(len),
        size = len,
        cursor = 0,
        references = {},
    }

    buffer.copy(nb.buff, 0, b)

    return nb
end
function alloc(buf: buffer_writer, bytes: number)
    if not (buf.cursor + bytes >= buf.size) then
        return
    end

    buf.size = math.floor(buf.size * 1.5)

    local newBuffer = buffer.create(buf.size)

    buffer.copy(newBuffer, 0, buf.buff)

    buf.buff = newBuffer
end
function dyn_alloc(buf: buffer_writer, bytes: number)
    while buf.cursor + bytes > buf.size do
        buf.size = math.floor(buf.size * 1.5)
    end

    local newBuffer = buffer.create(buf.size)

    buffer.copy(newBuffer, 0, buf.buff)

    buf.buff = newBuffer
end
function u8(buf: buffer_writer, value: number)
    buffer.writeu8(buf.buff, buf.cursor, value)

    buf.cursor += 1
end
function i8(buf: buffer_writer, value: number)
    buffer.writei8(buf.buff, buf.cursor, value)

    buf.cursor += 1
end
function reference(buf: buffer_writer, value: any)
    table.insert(buf.references, value)

    local index = #buf.references

    buffer.writeu8(buf.buff, buf.cursor, index)

    buf.cursor += 1
end
function u16(buf: buffer_writer, value: number)
    buffer.writeu16(buf.buff, buf.cursor, value)

    buf.cursor += 2
end
function i16(buf: buffer_writer, value: number)
    buffer.writeu16(buf.buff, buf.cursor, value)

    buf.cursor += 2
end
function u32(buf: buffer_writer, value: number)
    buffer.writeu32(buf.buff, buf.cursor, value)

    buf.cursor += 4
end
function writestring(buf: buffer_writer, value: string)
    buffer.writestring(buf.buff, buf.cursor, value)

    buf.cursor += string.len(value)
end
function i32(buf: buffer_writer, value: number)
    buffer.writei32(buf.buff, buf.cursor, value)

    buf.cursor += 4
end
function f32(buf: buffer_writer, value: number)
    buffer.writef32(buf.buff, buf.cursor, value)

    buf.cursor += 4
end
function f64(buf: buffer_writer, value: number)
    buffer.writef64(buf.buff, buf.cursor, value)

    buf.cursor += 8
end
function copy(buf: buffer_writer, value)
    buffer.copy(buf.buff, buf.cursor, value)

    buf.cursor += buffer.len(value)
end
function btrue(buf: buffer_writer)
    buffer.writeu8(buf.buff, buf.cursor, 1)

    buf.cursor += 1
end
function bfalse(buf: buffer_writer)
    buffer.writeu8(buf.buff, buf.cursor, 0)

    buf.cursor += 1
end

return table.freeze({
    create = create,
    alloc = alloc,
    u8 = u8,
    i8 = i8,
    u16 = u16,
    i16 = i16,
    u32 = u32,
    i32 = i32,
    f32 = f32,
    f64 = f64,
    copy = copy,
    btrue = btrue,
    bfalse = bfalse,
    reference = reference,
    writestring = writestring,
    dyn_alloc = dyn_alloc,
    from = from,
})
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="2">
      <Properties>
        <string name="Name">client-lifecycle</string>
        <string name="Source"><![CDATA[local Players = game:GetService('Players')
local ReplicatedStorage = game:GetService('ReplicatedStorage')
local RunService = game:GetService('RunService')
local read_iter = require(script.Parent:WaitForChild('read-iter'))
local buffer_writer = require(script.Parent:WaitForChild('buffer-writer'))
local alloc = buffer_writer.alloc
local u8 = buffer_writer.u8
local u16 = buffer_writer.u16
local dump = require(script.Parent:WaitForChild('dump'))
local read = require(script.Parent:WaitForChild('read'))

@native
function create_super(): buffer_writer.buffer_writer
    return {
        size = 256,
        cursor = 0,
        buff = buffer.create(256),
        references = {},
    }
end

local payload_reliable = create_super()
local payload_unreliable = create_super()

@native
function send_reliable_packet(id: number, writer: (buf:buffer_writer.buffer_writer, data:any) -> (), data: any)
    alloc(payload_reliable, 1)
    u8(payload_reliable, id)
    writer(payload_reliable, data)
end
@native
function send_unreliable_packet(id: number, writer: (buf:buffer_writer.buffer_writer, data:any) -> (), data: any)
    alloc(payload_unreliable, 1)
    u8(payload_unreliable, id)
    writer(payload_unreliable, data)
end
@native
function invoke_request(
    id: number,
    writer: (buf:buffer_writer.buffer_writer, data:any) -> (),
    reader: (buf:buffer_writer.buffer_writer, cursor:number) -> any,
    data: any
): (boolean,any)
    local buf = create_super()

    alloc(buf, 1)
    u8(buf, id)
    writer(buf, data)

    local remote_fn: RemoteFunction = ReplicatedStorage:WaitForChild('.remote_fn', math.huge)
    local success, nbuf, refs = remote_fn:InvokeServer(dump(buf))

    if (success) then
        local bc = buffer_writer.from(nbuf)

        bc.references = refs

        return true, reader(bc, 0)
    end

    return false
end
@native
function start()
    local reliable: RemoteEvent = ReplicatedStorage:WaitForChild('.reliable', math.huge)

    reliable.OnClientEvent:Connect(read)

    local unreliable: UnreliableRemoteEvent = ReplicatedStorage:WaitForChild('.unreliable', math.huge)

    unreliable.OnClientEvent:Connect(read)
    RunService.Heartbeat:Connect(function()
        if payload_reliable.cursor > 0 then
            local dump, refs = dump(payload_reliable)

            reliable:FireServer(dump, refs)

            payload_reliable.cursor = 0

            table.clear(payload_reliable.references)
        end
        if payload_unreliable.cursor > 0 then
            local b, r = dump(payload_unreliable)

            unreliable:FireServer(b, r)

            payload_unreliable.cursor = 0

            table.clear(payload_unreliable.references)
        end
    end)
end

return {
    start = start,
    send_reliable_packet = send_reliable_packet,
    send_unreliable_packet = send_unreliable_packet,
    invoke_request = invoke_request,
}
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="3">
      <Properties>
        <string name="Name">constants</string>
        <string name="Source"><![CDATA[local EVENT_TYPE = table.freeze({
    RELIABLE = 0,
    UNRELIABLE = 1,
})
local FUNCTION_STATUS = table.freeze({
    IN_PROGRESS = 2,
    PASS = 1,
    FAIL = 0,
})

return {
    EVENT_TYPE = EVENT_TYPE,
    FUNCTION_STATUS = FUNCTION_STATUS,
}
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="4">
      <Properties>
        <string name="Name">dump</string>
        <string name="Source"><![CDATA[local buffer_writer = require(script.Parent:WaitForChild('buffer-writer'))

return @native
function(b: buffer_writer.buffer_writer): (buffer,{unknown}?)
    local cursor = b.cursor
    local dumpBuffer = buffer.create(cursor)

    buffer.copy(dumpBuffer, 0, b.buff, 0, cursor)

    return dumpBuffer, if#b.references > 0 then b.references else nil
end
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="5">
      <Properties>
        <string name="Name">fire-listeners</string>
        <string name="Source"><![CDATA[local types = require(script.Parent:WaitForChild('types'))

return function(listeners: {types.fn_listener}, ...)
    local s = #listeners

    for i = 1, s do
        local r = listeners[i]

        if (r == nil) then
            break
        end
        if (r.once) then
            table.remove(listeners, i)
        end

        task.defer(r.fn, ...)
    end
end
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="6">
      <Properties>
        <string name="Name">logger</string>
        <string name="Source"><![CDATA[local fire_listeners = require(script.Parent:WaitForChild('fire-listeners'))
local template = '[sendbufs]: %s'

function white(...: string)
    print(template:format(table.concat({...}, ', ')))
end
function red(...: string)
    error(template:format(table.concat({...}, ', ')))
end
function orange(...: string)
    warn(template:format(table.concat({...}, ', ')))
end
function handler(err)
    red(err)
end
function errorif(cond: boolean, ...: string)
    if (cond) then
        red(...)
    end
end

return {
    errorif = errorif,
    white = white,
    red = red,
    orange = orange,
    handler = handler,
}
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="7">
      <Properties>
        <string name="Name">metatables</string>
        <string name="Source"><![CDATA[local Players = game:GetService('Players')
local RunService = game:GetService('RunService')
local client_lifecycle = require(script.Parent:WaitForChild('client-lifecycle'))
local server_lifecycle = require(script.Parent:WaitForChild('server-lifecycle'))
local types = require(script.Parent:WaitForChild('types'))
local serdes = require(script.Parent:WaitForChild('serdes'))
local constants = require(script.Parent:WaitForChild('constants'))
local client_remote_metatable = {}

client_remote_metatable.__index = client_remote_metatable

local server_remote_metatable = {}

server_remote_metatable.__index = server_remote_metatable

local server_function_metatable = {}

server_function_metatable.__index = server_function_metatable

local client_function_metatable = {}

client_function_metatable.__index = client_function_metatable

type event_comb_mt<T> = {__index: event_comb_mt<T>, connect: (self:t_event<T>, callback:(T, plr:Player?) -> (), once:boolean?) -> () -> (), wait: () -> (T,Player?), fire_client: (self:t_event<T>, plr:Player | {Player}, arg:T) -> (), fire_all: (self:t_event<T>, arg:T) -> (), fire_server: (self:t_event<T>, arg:T) -> ()}
type fn_comb_mt<T, R> = {__index: fn_comb_mt<T, R>, invoke: (self:t_fn<T, R>, input:T) -> (boolean,R), set_callback: (self:t_fn<T, R>, cb:(T, plr:Player) -> R) -> ()}
export type t_event<T> = typeof(setmetatable({}::{kind: 'event', listeners: {types.fn_listener}, schema: serdes.serdes_data<T>, type: number, id: number}, ((RunService.IsServer() and server_remote_metatable or client_remote_metatable)::never)::event_comb_mt<T>))
export type t_fn<T, R> = typeof(setmetatable({}::{kind: 'function', callback: ((arg:T, plr:Player?) -> R)?, schema: serdes.serdes_data<T>, schema_out: serdes.serdes_data<{any}>, id: number}, ((RunService.IsServer() and server_function_metatable or client_function_metatable)::never)::fn_comb_mt<T, R>))

function connect_listener(listeners: {types.fn_listener}, fn: (...any) -> (), once: boolean?)
    local t = {
        fn = fn,
        once = once,
    }

    table.insert(listeners, t)

    return function()
        local i = table.find(listeners, t)

        if i ~= nil then
            table.remove(listeners, i)
        end
    end
end
function wait<T>(self: t_event<T>): (T,Player?)
    local coro = coroutine.running()
    local data, plr

    connect_listener(self.listeners, function(...)
        data, plr = ...

        task.defer(coro)
    end, true)
    coroutine.yield()

    return data, plr
end
function connect<T>(self: t_event<T>, callback: (T) -> (), once: boolean?)
    return connect_listener(self.listeners, callback, once)
end
function to_player_table(t: Player | {Player}): {Player}
    if typeof(t) == 'table' then
        return t
    end

    return {t}
end
function client_remote_metatable.fire_server<T>(self: t_event<T>, arg: T)
    local write_fn = self.schema.write
    local fn = if self.type == constants.EVENT_TYPE.RELIABLE then client_lifecycle.send_reliable_packet else client_lifecycle.send_unreliable_packet;

    (fn::never)(self.id, write_fn, arg)
end

client_remote_metatable.wait = wait
client_remote_metatable.connect = connect

table.freeze(client_remote_metatable)

function client_function_metatable.invoke<T, R>(self: t_fn<T, R>, arg: T): (boolean,R)
    local write_fn = self.schema.write
    local read_fn = self.schema_out.read

    return client_lifecycle.invoke_request(self.id, write_fn, read_fn, arg)
end

table.freeze(client_function_metatable)

function server_remote_metatable.fire_client<T>(
    self: t_event<T>,
    plr: Player | {Player},
    arg: T
): ()
    local plr = to_player_table(plr)
    local write_fn = self.schema.write
    local fn = if self.type == constants.EVENT_TYPE.RELIABLE then server_lifecycle.send_reliable_packet else server_lifecycle.send_reliable_packet

    for i = 1, #plr do
        (fn::never)(plr[i], self.id, write_fn, arg)
    end
end
function server_remote_metatable.fire_all<T>(self: t_event<T>, arg: T): ()
    local plr = Players:GetPlayers()
    local write_fn = self.schema.write
    local fn = if self.type == constants.EVENT_TYPE.RELIABLE then server_lifecycle.send_reliable_packet else server_lifecycle.send_reliable_packet

    for i = 1, #plr do
        (fn::never)(plr[i], self.id, write_fn, arg)
    end
end

server_remote_metatable.wait = wait
server_remote_metatable.connect = connect

table.freeze(server_remote_metatable)

function server_function_metatable.set_callback<T, R>(
    self: t_fn<T, R>,
    cb: (arg:T, plr:Player?) -> R
)
    if (self.callback) then
        error('CALLBACK FN ALREADY EXISTS!')
    end

    self.callback = cb
end

table.freeze(server_function_metatable)

return table.freeze{
    client_remote_metatable = client_remote_metatable,
    client_function_metatable = client_function_metatable,
    server_remote_metatable = server_remote_metatable,
    server_function_metatable = server_function_metatable,
}
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="8">
      <Properties>
        <string name="Name">middleware</string>
        <string name="Source"><![CDATA[local RunService = game:GetService('RunService')
local remotes = require(script.Parent:WaitForChild('remotes'))

type middleware_fn = (id:number, plr:Player, b:buffer, refs:{unknown}?) -> boolean

local added: {[number]: {middleware_fn}} = {}

function middleware<T, R>(net: any, fn: middleware_fn)
    local array = added[net.id] or {}

    table.insert(array, fn)

    added[net.id] = array
end
function global_middleware(fn: middleware_fn)
    for r in remotes do
        local array = added[r] or {}

        table.insert(array, fn)

        added[r] = array
    end
end
function run_middleware_for(
    id: number,
    plr: Player,
    b: buffer,
    refs: {unknown}?
)
    if (not RunService:IsServer()) then
        return true
    end

    local array = added[id]

    if not array then
        return true
    end

    for _, fn in array do
        if not fn(id, plr, b, refs) then
            return false
        end
    end

    return true
end

return {
    middleware = middleware,
    global_middleware = global_middleware,
    run_middleware_for = run_middleware_for,
}
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="9">
      <Properties>
        <string name="Name">read-iter</string>
        <string name="Source"><![CDATA[local buffer_writer = require(script.Parent:WaitForChild('buffer-writer'))
local fire_listeners = require(script.Parent:WaitForChild('fire-listeners'))
local remotes = require(script.Parent:WaitForChild('remotes'))
local from = buffer_writer.from

@native
function read_iter(reader_prop: string, b: buffer, refs: {unknown}?)
    local cursor = 0
    local totalLen = buffer.len(b)
    local sb = from(b)

    sb.references = refs or {}

    return function()
        if cursor >= totalLen then
            return
        end

        local rid = buffer.readu8(b, cursor)
        local remo = remotes[rid]

        cursor += 1

        local value, nc = remo[reader_prop].read(sb, cursor)

        cursor += nc

        return rid, value
    end
end

return (read_iter::never)::<T...>(reader_prop:string, b:buffer, refs:{unknown}?) -> () -> (number,any)
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="10">
      <Properties>
        <string name="Name">read</string>
        <string name="Source"><![CDATA[local Players = game:GetService('Players')
local buffer_writer = require(script.Parent:WaitForChild('buffer-writer'))
local fire_listeners = require(script.Parent:WaitForChild('fire-listeners'))
local middleware = require(script.Parent:WaitForChild('middleware'))
local remotes = require(script.Parent:WaitForChild('remotes'))
local from = buffer_writer.from

return @native
function(b: buffer, refs: {unknown}?, plr: Player?)
    local cursor = 0
    local totalLen = buffer.len(b)
    local sb = from(b)

    sb.references = refs or {}

    while cursor < totalLen do
        local id = buffer.readu8(b, cursor)
        local remo = remotes[id]

        cursor += 1

        local value, nc = remo.schema.read(sb, cursor)

        cursor += nc

        if remo.kind == 'event' and remo.listeners ~= nil then
            if plr and not middleware.run_middleware_for(id, plr, b, refs) then
                continue
            end

            fire_listeners(remo.listeners, value, plr)
        end
    end
end
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="11">
      <Properties>
        <string name="Name">remotes</string>
        <string name="Source"><![CDATA[type reflist = {any}

local refs: reflist = {}

return refs
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="12">
      <Properties>
        <string name="Name">serdes</string>
        <string name="Source"><![CDATA[local buffer_writer = require(script.Parent:WaitForChild('buffer-writer'))
local alloc = buffer_writer.alloc
local dyn_alloc = buffer_writer.dyn_alloc
local u8 = buffer_writer.u8
local u16 = buffer_writer.u16
local u32 = buffer_writer.u32
local i8 = buffer_writer.i8
local i16 = buffer_writer.i16
local i32 = buffer_writer.i32
local f32 = buffer_writer.f32
local btrue = buffer_writer.btrue
local bfalse = buffer_writer.bfalse
local reference = buffer_writer.reference
local writestring = buffer_writer.writestring

export type serdes_data<T> = {read: (buff:buffer_writer.buffer_writer, cursor:number) -> (T,number), write: (buff:buffer_writer.buffer_writer, v:T) -> ()}

do
    local data: serdes_data<boolean> = {
        read = function(b, o)
            return (buffer.readu8(b.buff, o) == 1), 1
        end,
        write = function(b, v)
            alloc(b, 1)

            if v then
                btrue(b)
            else
                bfalse(b)
            end
        end,
    }

    function S_BOOL()
        return data
    end
end
do
    local data: serdes_data<number> = {
        read = function(b, o)
            return buffer.readu8(b.buff, o), 1
        end,
        write = function(b, v)
            alloc(b, 1)
            u8(b, v)
        end,
    }

    function S_U8()
        return data
    end
end
do
    local data: serdes_data<number> = {
        read = function(b, o)
            return buffer.readi8(b.buff, o), 1
        end,
        write = function(b, v)
            alloc(b, 1)
            i8(b, v)
        end,
    }

    function S_I8()
        return data
    end
end
do
    local data: serdes_data<number> = {
        read = function(b, o)
            return buffer.readu16(b.buff, o), 2
        end,
        write = function(b, v)
            alloc(b, 2)
            u16(b, v)
        end,
    }

    function S_U16()
        return data
    end
end
do
    local data: serdes_data<number> = {
        read = function(b, o)
            return buffer.readi16(b.buff, o), 2
        end,
        write = function(b, v)
            alloc(b, 2)
            i16(b, v)
        end,
    }

    function S_I16()
        return data
    end
end
do
    local data: serdes_data<number> = {
        read = function(b, o)
            return buffer.readu32(b.buff, o), 4
        end,
        write = function(b, v)
            alloc(b, 4)
            u32(b, v)
        end,
    }

    function S_U32()
        return data
    end
end
do
    local data: serdes_data<number> = {
        read = function(b, o)
            return buffer.readi32(b.buff, o), 4
        end,
        write = function(b, v)
            alloc(b, 4)
            i32(b, v)
        end,
    }

    function S_I32()
        return data
    end
end
do
    function S_TUPLE(...: serdes_data<any>)
        local packed = table.pack(...)
        local tuple_len = packed.n
        local data: serdes_data<{any}> = {
            read = function(b, cursor)
                local len = buffer.readu8(b.buff, cursor)
                local array = {}
                local arr_cursor = cursor + 1

                for i = 1, len do
                    local v, len = packed[i].read(b, arr_cursor)

                    array[i] = v

                    arr_cursor += len
                end

                return array, arr_cursor - cursor
            end,
            write = function(b, v)
                alloc(b, 1)
                u8(b, tuple_len)

                for i = 1, tuple_len do
                    packed[i].write(b, v[i])
                end
            end,
        }

        return data
    end
end
do
    function S_ARRAY<T>(t: serdes_data<T>)
        local read, write = t.read, t.write
        local data: serdes_data<{T}> = {
            read = function(b, cursor)
                local len = buffer.readu16(b.buff, cursor)
                local array = {}
                local arr_cursor = cursor + 2

                for i = 1, len do
                    local v, len = read(b, arr_cursor)

                    array[i] = v

                    arr_cursor += len
                end

                return array, arr_cursor - cursor
            end,
            write = function(b, v)
                local s = #v

                alloc(b, 2)
                u16(b, s)

                for i = 1, s do
                    write(b, v[i])
                end
            end,
        }

        return data
    end
end
do
    local map = {}

    function get_struct(template: {[string]: serdes_data<any>})
        if map[template] ~= nil then
            return map[template], #map[template]
        end

        local converted_struct = {}

        for i, v in template do
            converted_struct[#converted_struct + 1] = {
                index = i,
                val = v,
            }
        end

        table.sort(converted_struct, function(a0, a1): boolean
            return a0.index > a1.index
        end)

        local len = #converted_struct

        map[template] = converted_struct

        return converted_struct, len
    end
    function S_STRUCT(template: {[string]: serdes_data<any>})
        local ordered, len = get_struct(template)

        print(ordered, len, 'STRUCT')

        local data: serdes_data<{[string]: serdes_data<any>}> = {
            read = function(buff, cursor)
                local length = buffer.readu8(buff.buff, cursor)
                local str_cursor = cursor + 1
                local struct = {}

                for i = 1, length do
                    local r = ordered[i]
                    local value, offset = r.val.read(buff, str_cursor)

                    struct[r.index] = value

                    str_cursor += offset
                end

                return struct, str_cursor - cursor
            end,
            write = function(b, v)
                alloc(b, 1)
                u8(b, len)

                for i = 1, len do
                    local r = ordered[i]

                    r.val.write(b, v[r.index])
                end
            end,
        }

        return data
    end
end
do
    function S_OPTIONAL<T>(v: serdes_data<T>): serdes_data<T?>
        local read, write = v.read, v.write

        return {
            read = function(b, cursor)
                if buffer.readu8(b.buff, cursor) == 0 then
                    return nil, 1
                else
                    local item, length = read(b, cursor + 1)

                    return item, length + 1
                end
            end,
            write = function(b, value)
                local exists = value ~= nil

                alloc(b, 1)

                if exists then
                    btrue(b)
                else
                    bfalse(b)
                end
                if exists then
                    write(b, value::T)
                end
            end,
        }
    end
end
do
    local data: serdes_data<any> = {
        read = function(b, cursor)
            local v = buffer.readu8(b.buff, cursor)

            return b.references[v], 1
        end,
        write = function(b, v)
            alloc(b, 1)
            reference(b, v)
        end,
    }

    function S_REF()
        return data
    end
end
do
    local data: serdes_data<nil> = {
        read = function()
            return nil, 0
        end,
        write = function() end,
    }

    function S_NONE()
        return data
    end
end
do
    local bor = bit32.bor
    local data: serdes_data<vector> = {
        read = function(b, cursor)
            local c = cursor
            local x = buffer.readi16(b.buff, c)

            c += 2

            local y = buffer.readi16(b.buff, c)

            c += 2

            local z = buffer.readi16(b.buff, c)

            c += 2

            return vector.create(x, y, z), c - cursor
        end,
        write = function(b, v)
            alloc(b, 6)
            i16(b, bor(v.x, 0))
            i16(b, bor(v.y, 0))
            i16(b, bor(v.z or 0, 0))
        end,
    }

    function VECI16()
        return data
    end
end
do
    local bor = bit32.bor
    local data: serdes_data<vector> = {
        read = function(b, cursor)
            local c = cursor
            local x = buffer.readi32(b.buff, c)

            c += 4

            local y = buffer.readi32(b.buff, c)

            c += 4

            local z = buffer.readi32(b.buff, c)

            c += 4

            return vector.create(x, y, z), c - cursor
        end,
        write = function(b, v)
            alloc(b, 12)
            i32(b, bor(v.x, 0))
            i32(b, bor(v.y, 0))
            i32(b, bor(v.z or 0, 0))
        end,
    }

    function VECI32()
        return data
    end
end
do
    local data: serdes_data<vector> = {
        read = function(b, cursor)
            local c = cursor
            local x = buffer.readf32(b.buff, c)

            c += 4

            local y = buffer.readf32(b.buff, c)

            c += 4

            local z = buffer.readf32(b.buff, c)

            c += 4

            return vector.create(x, y, z), c - cursor
        end,
        write = function(b, v)
            alloc(b, 12)
            f32(b, v.x)
            f32(b, v.y)
            f32(b, v.z or 0)
        end,
    }

    function VECF32()
        return data
    end
end
do
    local data: serdes_data<CFrame> = {
        read = function(b, cursor)
            local c = cursor
            local x = buffer.readf32(b.buff, c)

            c += 4

            local y = buffer.readf32(b.buff, c)

            c += 4

            local z = buffer.readf32(b.buff, c)

            c += 4

            local rx = buffer.readf32(b.buff, c)

            c += 4

            local ry = buffer.readf32(b.buff, c)

            c += 4

            local rz = buffer.readf32(b.buff, c)

            c += 4

            return CFrame.Angles(rx, ry, rz) + Vector3.new(x, y, z), c - cursor
        end,
        write = function(b, v)
            local unit, rot = v:ToAxisAngle()

            unit *= rot

            alloc(b, 24)
            f32(b, v.x)
            f32(b, v.y)
            f32(b, v.z)
            f32(b, unit.x)
            f32(b, unit.y)
            f32(b, unit.z)
        end,
    }

    function CFRAME()
        return data
    end
end
do
    local data: serdes_data<string> = {
        read = function(b, cursor)
            local c = cursor
            local len = buffer.readu16(b.buff, c)

            c += 2

            local str = buffer.readstring(b.buff, c, len)

            c += len

            return str, c - cursor
        end,
        write = function(b, v)
            local len = #v

            alloc(b, 2)
            u16(b, len)
            dyn_alloc(b, len)
            writestring(b, v)
        end,
    }

    function STRING()
        return data
    end
end

return table.freeze({
    NONE = (S_NONE()::never)::nil,
    REF = (S_REF()::never)::any,
    BOOL = (S_BOOL()::never)::boolean,
    U8 = (S_U8()::never)::number,
    I8 = (S_I8()::never)::number,
    U16 = (S_U16()::never)::number,
    I16 = (S_I16()::never)::number,
    U32 = (S_U32()::never)::number,
    I32 = (S_I32()::never)::number,
    VECI16 = (VECI16()::never)::vector,
    VECI32 = (VECI32()::never)::vector,
    VECF32 = (VECF32()::never)::vector,
    STRING = (STRING()::never)::string,
    CFRAME = (CFRAME()::never)::CFrame,
    ARRAY = (S_ARRAY::never)::<T>(T) -> {T},
    STRUCT = (S_STRUCT::never)::<T>(T) -> T,
    OPTIONAL = (S_OPTIONAL::never)::<T>(T) -> T?,
})
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="13">
      <Properties>
        <string name="Name">server-lifecycle</string>
        <string name="Source"><![CDATA[local Players = game:GetService('Players')
local ReplicatedStorage = game:GetService('ReplicatedStorage')
local RunService = game:GetService('RunService')
local remotes = require(script.Parent:WaitForChild('remotes'))
local read_iter = require(script.Parent:WaitForChild('read-iter'))
local read = require(script.Parent:WaitForChild('read'))
local buffer_writer = require(script.Parent:WaitForChild('buffer-writer'))
local alloc = buffer_writer.alloc
local u8 = buffer_writer.u8
local dump = require(script.Parent:WaitForChild('dump'))
local logger = require(script.Parent:WaitForChild('logger'))
local middleware = require(script.Parent:WaitForChild('middleware'))
local validate_buffer = require(script.Parent:WaitForChild('validate-buffer'))

@native
function create_super(): buffer_writer.buffer_writer
    return {
        size = 256,
        cursor = 0,
        buff = buffer.create(256),
        references = {},
    }
end

local players_reliable: {[Player]: buffer_writer.buffer_writer?} = {}
local players_unreliable: {[Player]: buffer_writer.buffer_writer?} = {}

@native
function send_reliable_packet(
    to: Player,
    id: number,
    writer: (buf:buffer_writer.buffer_writer, data:any) -> (),
    data: any
)
    local buf = players_reliable[to] or create_super()

    alloc(buf, 2)
    u8(buf, id)
    writer(buf, data)

    players_reliable[to] = buf
end
@native
function send_unreliable_packet(
    to: Player,
    id: number,
    writer: (buf:buffer_writer.buffer_writer, data:any) -> (),
    data: any
)
    local buf = players_unreliable[to] or create_super()

    alloc(buf, 2)
    u8(buf, id)
    writer(buf, data)

    players_unreliable[to] = buf
end
@native
function start()
    local reliable = Instance.new('RemoteEvent')

    reliable.Name = '.reliable'

    local unreliable = Instance.new('UnreliableRemoteEvent')

    unreliable.Name = '.unreliable'

    local remote_fn = Instance.new('RemoteFunction')

    remote_fn.Name = '.remote_fn'
    remote_fn.OnServerInvoke = function(plr, b, ref)
        logger.errorif(not validate_buffer(b, ref), 'INVALID BUFFER')

        for nid, val in read_iter('schema', b)do
            if not middleware.run_middleware_for(nid, plr, b, ref) then
                continue
            end
            if (remotes[nid] == nil or remotes[nid].kind ~= 'function') then
                logger.orange('INVALID FUNCTION')

                return false
            end

            local success, res = pcall(remotes[nid].callback, val, plr)

            if (not success) then
                return false
            end

            local buf = create_super()

            remotes[nid].schema_out.write(buf, res)

            local r, refs = dump(buf)

            return true, r, refs
        end

        logger.orange('INVALID ID')

        return false
    end

    reliable.OnServerEvent:Connect(function(plr: Player, b, r)
        logger.errorif(not validate_buffer(b, r), 'INVALID BUFFER')
        read(b, r, plr)
    end)
    unreliable.OnServerEvent:Connect(function(plr: Player, b, r)
        logger.errorif(not validate_buffer(b, r), 'INVALID BUFFER')
        read(b, r, plr)
    end)

    reliable.Parent = ReplicatedStorage
    unreliable.Parent = ReplicatedStorage
    remote_fn.Parent = ReplicatedStorage

    RunService.Heartbeat:Connect(function()
        for _, plr in Players:GetPlayers()do
            do
                local buf = players_reliable[plr]

                if buf ~= nil and buf.cursor > 0 then
                    local dumpBuffer, references = dump(buf)

                    reliable:FireClient(plr, dumpBuffer, references)

                    buf.cursor = 0

                    table.clear(buf.references)
                end
            end
            do
                local buf = players_unreliable[plr]

                if buf ~= nil and buf.cursor > 0 then
                    local dumpBuffer, references = dump(buf)

                    unreliable:FireClient(plr, dumpBuffer, references)

                    buf.cursor = 0

                    table.clear(buf.references)
                end
            end
        end
    end)
end

return {
    start = start,
    send_reliable_packet = send_reliable_packet,
    send_unreliable_packet = send_unreliable_packet,
}
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="14">
      <Properties>
        <string name="Name">types</string>
        <string name="Source"><![CDATA[export type fn_listener = {fn: () -> (), once: boolean?}

return nil
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="15">
      <Properties>
        <string name="Name">validate-buffer</string>
        <string name="Source"><![CDATA[return function(b: any, refs: {unknown}?)
    if (refs and typeof(refs) ~= 'table') then
        return false
    end

    return typeof(b) == 'buffer' and buffer.len(b) > 0
end
]]></string>
      </Properties>
    </Item>
  </Item>
</roblox>